exec composer create-project --quiet --no-install roots/bedrock bedrock
cd bedrock

exec composer config --quiet secure-http false
exec composer require --quiet --no-install wp-plugin/woocommerce:10.0.0

exec composer audit --locked --format=json
cmp stdout ../stdout.golden

