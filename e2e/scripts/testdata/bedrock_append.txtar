[!composer:2.9] skip 'Subcommand "repo" is added in Composer v2.9'

exec composer create-project --quiet --no-install roots/bedrock bedrock
cd bedrock

exec composer config --quiet secure-http false
exec composer repo --append add wpsecadv composer $WPSECADV_SERVER_URL

exec composer require --quiet --no-install wp-plugin/woocommerce:10.0.0

! exec composer audit --locked --format=json

# Core
stdout CVE-2017-14990
stdout CVE-2022-3590

# WooCommerce
stdout CVE-2025-15033
stdout CVE-2025-49042
